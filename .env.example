# Google Gemini API Configuration
GEMINI_API_KEY=

# Llama.cpp Server Configuration
LLAMA_SERVER_URL=http://localhost:8080

# Llama.cpp Server Executable Path (for auto-start)
# Example: C:\llama-b8829-bin-win-cpu-x64\llama-server.exe
# Leave empty to disable auto-start
LLAMA_SERVER_PATH=

# Auto-start Llama server (true/false)
LLAMA_AUTO_START=true

# Image Processing
IMAGE_SIZE=256

# Logging
LOG_LEVEL=INFO
